{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "matches.js": { "runtime": "nodejs18.x" },
    "teams.js": { "runtime": "nodejs18.x" },
    "match.js": { "runtime": "nodejs18.x" }
  },
  "rewrites": [
    { "source": "/api/matches", "destination": "/matches" },
    { "source": "/api/teams", "destination": "/teams" },
    { "source": "/api/match", "destination": "/match" }
  ]
}


